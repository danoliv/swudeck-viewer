{
  "name": "swudeck-viewer",
  "version": "1.0.0",
  "description": "Star Wars Unlimited Deck Viewer",
  "main": "index.html",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:docs": "VITE_OUT_DIR=docs VITE_BASE=/swudeck-viewer/ vite build",
    "preview": "vite preview",
    "start": "vite",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots",
    "test:e2e:headed": "playwright test --headed",
    "fetch-sets": "node fetch-sets.js",
    "fetch-icons": "node fetch-aspect-icons.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@vitest/coverage-v8": "^3.2.3",
    "happy-dom": "^18.0.1",
    "jest-fetch-mock": "^3.0.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^3.2.3"
  }
}