{
  "name": "swudeck-viewer",
  "version": "1.0.0",
  "description": "Star Wars Unlimited Deck Viewer",
  "main": "index.html",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:docs": "VITE_OUT_DIR=docs VITE_BASE=/swudeck-viewer/ vite build",
    "preview": "vite preview",
    "start": "vite",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots",
    "test:e2e:headed": "playwright test --headed",
    "fetch-sets": "node fetch-sets.js",
    "check-new-sets": "node scripts/check-new-sets.js",
    "fetch-icons": "node fetch-aspect-icons.js",
    "fetch-swubase": "node scripts/fetch-swubase.js",
    "db:link": "supabase link",
    "db:push": "supabase db push",
    "db:pull": "supabase db pull",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:status": "supabase status",
    "db:migration": "supabase migration new"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@vitest/coverage-v8": "^3.2.3",
    "happy-dom": "^18.0.1",
    "jest-fetch-mock": "^3.0.3",
    "supabase": "^2.107.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^3.2.3"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2"
  }
}
